# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins (frontend URLs).
# Use * only for quick local testing.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Database ───────────────────────────────────────────
# SQLite by default (zero-config). For Postgres, switch the
# provider in prisma/schema.prisma and set a postgres URL here.
DATABASE_URL="file:./dev.db"

# ── Auth ───────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION. Use long random strings.
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Default admin account created on seed (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=مدیر سیستم
